      basicInfo: 'Basic Information',
      pageTitle: 'Page Title',
      reviewDate: 'Review Date',
      totalComments: 'Total Comments',
      commentsCount: 'comments',
      reviewOpinions: 'Review Opinions',
      p0Must: 'P0 — Must Fix',
      p1Should: 'P1 — Should Fix',
      p2Optional: 'P2 — Optional',
      noOpinions: 'No review opinions.',
      savePath: 'Save Path',
      usage: 'Usage',
      usageInstruction: 'Copy this document and paste to Claude, then say "I have completed the review, please help me save the review record"',

      // Toast messages
      noCommentsToExport: 'No comments yet. Please add comments before exporting.',
      fileDownloaded: 'File download started!',
      copiedToClipboard: 'Copied to clipboard!',
      pleaseEnterContent: 'Please enter comment content',

      // Logs
      initialized: 'initialized',
