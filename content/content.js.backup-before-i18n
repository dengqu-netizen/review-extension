  // ==================== 下载 Markdown 文件 ====================
  function downloadMarkdown(markdown) {
    const today = new Date();
    const year = today.getFullYear();
    const month = String(today.getMonth() + 1).padStart(2, '0');
    const day = String(today.getDate()).padStart(2, '0');
    const dateForFilename = `${year}-${month}-${day}`;
    const pageName = window.location.pathname.split('/').pop().replace('.html', '') || 'prototype';
    const filename = `${pageName}-dq-review-${dateForFilename}.md`;

    const blob = new Blob([markdown], { type: 'text/markdown;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.style.display = 'none';

    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }

  // ==================== 生成 Markdown ====================
  function generateMarkdown() {
    const pageTitle = document.title || '未命名页面';
    const today = new Date();
    const dateStr = today.toLocaleDateString('zh-CN');
    const year = today.getFullYear();
    const month = String(today.getMonth() + 1).padStart(2, '0');
    const day = String(today.getDate()).padStart(2, '0');
    const dateForFilename = `${year}-${month}-${day}`;

    const pageName = window.location.pathname.split('/').pop().replace('.html', '') || 'prototype';

    const p0 = annotations.filter(a => a.priority === 'P0');
    const p1 = annotations.filter(a => a.priority === 'P1');
    const p2 = annotations.filter(a => a.priority === 'P2');

    let fullPath = decodeURIComponent(window.location.pathname);
    let savePath = '';

    const prototypesMatch = fullPath.match(/^(.+)\/(03_prototypes?|prototypes?)\/([^\/]+)\.html$/);
    if (prototypesMatch) {
      const [, basePath, , fileName] = prototypesMatch;
      savePath = `${basePath}/05_reviews/${fileName}-dq-review-${dateForFilename}.md`;
    } else {
      const dirMatch = fullPath.match(/^(.+)\/([^\/]+)\/([^\/]+)\.html$/);
      if (dirMatch) {
        const [, parentPath] = dirMatch;
        savePath = `${parentPath}/05_reviews/${pageName}-dq-review-${dateForFilename}.md`;
      } else {
        savePath = `05_reviews/${pageName}-dq-review-${dateForFilename}.md`;
      }
    }

    let markdown = `<!--\n`;
    markdown += `保存路径：${savePath}\n`;
    markdown += `使用方式：复制此文档内容，粘贴给 Claude 并说 "我已经完成了评审，请帮我保存评审记录"\n`;
    markdown += `-->\n\n`;

    markdown += `# 原型评审记录\n\n`;
    markdown += `> 本文档由评审标注工具自动生成\n\n`;
    markdown += `## 基本信息\n\n`;
    markdown += `- 页面标题：${pageTitle}\n`;
    markdown += `- 评审日期：${dateStr}\n`;
    markdown += `- 评论总数：${annotations.length} 条（P0: ${p0.length} / P1: ${p1.length} / P2: ${p2.length}）\n\n`;

    markdown += `## 评审意见\n\n`;

    if (p0.length > 0) {
      markdown += `### P0 — 必须修改\n\n`;
      p0.forEach((a, index) => {
        markdown += `#### ${index + 1}. [${a.type}] ${a.content.split('\n')[0]}\n\n`;
        markdown += `${a.content}\n\n`;
      });
    }

    if (p1.length > 0) {
      markdown += `### P1 — 建议修改\n\n`;
      p1.forEach((a, index) => {
        markdown += `#### ${index + 1}. [${a.type}] ${a.content.split('\n')[0]}\n\n`;
        markdown += `${a.content}\n\n`;
      });
    }

    if (p2.length > 0) {
      markdown += `### P2 — 可选优化\n\n`;
      p2.forEach((a, index) => {
        markdown += `#### ${index + 1}. [${a.type}] ${a.content.split('\n')[0]}\n\n`;
        markdown += `${a.content}\n\n`;
      });
    }

    if (annotations.length === 0) {
      markdown += `暂无评审意见。\n`;
    }

    return markdown;
  }

  // ==================== 工具函数 ====================
  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function copyToClipboard(text) {
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    document.body.appendChild(textarea);
    textarea.select();
    document.execCommand('copy');
    document.body.removeChild(textarea);
  }

  // ==================== Toast 提示 ====================
  function showToast(message) {
    const toast = document.createElement('div');
    toast.className = 'dq-review-toast';
    toast.innerHTML = `
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
      <span>${escapeHtml(message)}</span>
    `;

    document.body.appendChild(toast);

    setTimeout(() => toast.classList.add('show'), 10);

    setTimeout(() => {
      toast.classList.remove('show');
      setTimeout(() => toast.remove(), 300);
    }, 3000);

    toast.addEventListener('click', () => {
      toast.classList.remove('show');
      setTimeout(() => toast.remove(), 300);
    });
  }

  // ==================== 数据持久化 ====================

  // 获取存储键（基于项目名 + 文件名）
  function getStorageKey() {
    const path = window.location.pathname;
    const fileName = path.split('/').pop() || 'index.html';

    // 尝试从路径提取项目名（匹配 /projects/{项目名}/ 模式）
    const projectMatch = path.match(/\/projects\/([^\/]+)\//);
    const projectName = projectMatch ? projectMatch[1] : 'default';

    return `${projectName}_${fileName}`;
  }

  function saveAnnotations() {
    const storageKey = getStorageKey();
    chrome.storage.local.set({
      [`annotations_${storageKey}`]: annotations,
      [`currentId_${storageKey}`]: currentAnnotationId
    });
    console.log(`[Review Extension V2] 已保存到: ${storageKey}`);
  }

  function loadAnnotations() {
    const storageKey = getStorageKey();
    chrome.storage.local.get([`annotations_${storageKey}`, `currentId_${storageKey}`], (result) => {
      annotations = result[`annotations_${storageKey}`] || [];
      currentAnnotationId = result[`currentId_${storageKey}`] || 0;
      console.log(`[Review Extension V2] 已从 ${storageKey} 加载 ${annotations.length} 条评论`);
    });
  }

  // ==================== 暴露全局接口 ====================
  window.reviewExtension = {
    locateAnnotation,
    deleteAnnotation
  };

  // ==================== 启动 ====================
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

})();
