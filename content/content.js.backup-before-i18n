  };

  // 翻译函数
  function t(key) {
    return i18n[userLang][key] || i18n['en'][key] || key;
  }

  console.log(`[Review Extension V2] v${VERSION} ${t('loaded')}`);

  // ==================== 状态管理 ====================
  let isReviewMode = false;
  let isPanelVisible = false;
  let annotations = [];
  let currentAnnotationId = 0;
  let selectedElement = null;
  let commentDialog = null;
  let reviewPanel = null;
  let commentListPanel = null;
  let hoverOverlay = null;
  let selectOverlay = null;

  // 核心映射表
  const annotationMarkerMap = new Map();      // annotationId → { marker, element }
  const annotationElementMap = new Map();      // annotationId → element（运行时引用）

  // ESC 双击检测
  let lastEscTime = 0;
  const ESC_DOUBLE_CLICK_THRESHOLD = 500;

  // 拖动状态
  let isDragging = false;
  let dragStartX = 0;
  let dragStartY = 0;
  let panelStartX = 0;
  let panelStartY = 0;

  // 鼠标移动目标
  let hoveredElement = null;

  // ==================== 初始化 ====================
  function init() {
    loadAnnotations();
    setupKeyboardShortcuts();
    setupGlobalScrollListener();
    createHoverOverlay();
    createSelectOverlay();
    console.log('[Review Extension V2] 已初始化');
  }

  // ==================== 全局滚动监听（架构改进3） ====================
  // 用捕获模式监听 document 上所有 scroll 事件，覆盖嵌套滚动容器
  function setupGlobalScrollListener() {
    document.addEventListener('scroll', () => {
      updateAllVisibleMarkerPositions();
      // 同步更新选中覆盖层
      if (selectedElement) {
        updateSelectOverlay(selectedElement);
      }
      // 同步更新悬停覆盖层
      if (hoveredElement && isReviewMode) {
        updateHoverOverlay(hoveredElement);
      }
    }, true); // 捕获模式：能捕获所有子容器的 scroll 事件

    // resize 同理
    window.addEventListener('resize', () => {
      updateAllVisibleMarkerPositions();
      if (selectedElement) {
        updateSelectOverlay(selectedElement);
      }
    });
  }

  // ==================== 快捷键监听 ====================
  function setupKeyboardShortcuts() {
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const currentTime = Date.now();
        if (currentTime - lastEscTime < ESC_DOUBLE_CLICK_THRESHOLD) {
          toggleReviewPanel();
          lastEscTime = 0;
        } else {
          lastEscTime = currentTime;
        }
      }
    });
  }

  // ==================== 评审面板 ====================
  function toggleReviewPanel() {
    if (isPanelVisible) {
      hideReviewPanel();
    } else {
      showReviewPanel();
    }
  }

  function showReviewPanel() {
    if (!reviewPanel) {
      createReviewPanel();
    }
    reviewPanel.style.display = 'flex';

    // 重置位置到初始状态（底部居中），清除拖动后的定位
    reviewPanel.style.left = '50%';
    reviewPanel.style.top = 'auto';
    reviewPanel.style.bottom = '20px';
    reviewPanel.style.right = 'auto';
    reviewPanel.style.transform = 'translateX(-50%)';

    // 添加落下动画
    reviewPanel.classList.remove('dq-review-panel-drop');
    void reviewPanel.offsetWidth; // 强制重排，重置动画
    reviewPanel.classList.add('dq-review-panel-drop');

    isPanelVisible = true;

    // 恢复角标：从 storage 重建缺失的，显示已有的
    rebuildAndShowMarkers();
    updateCommentBadge();
  }

  function hideReviewPanel() {
    if (reviewPanel) {
      reviewPanel.style.display = 'none';
    }
    isPanelVisible = false;

    // 架构改进1：隐藏角标而非销毁
    hideAllMarkers();
    hideCommentList();
    hideSelectOverlay();

    if (isReviewMode) {
      exitReviewMode();
    }
  }

  function createReviewPanel() {
    reviewPanel = document.createElement('div');
    reviewPanel.className = 'dq-review-panel';
    reviewPanel.innerHTML = `
      <div class="dq-review-panel-drag-handle" title="${t('dragHandle')}">⋮⋮</div>
      <button class="dq-review-btn dq-review-btn-primary" id="reviewToggleBtn">${t('startReview')}</button>
      <button class="dq-review-btn dq-review-btn-secondary dq-review-btn-with-badge" id="reviewViewCommentsBtn">
        ${t('viewRecords')}
        <span class="dq-review-badge" id="reviewCommentBadge">0</span>
      </button>
      <button class="dq-review-btn dq-review-btn-secondary" id="reviewExportBtn">${t('export')}</button>
      <button class="dq-review-btn-icon" id="reviewCloseBtn" title="${t('close')}">
        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 5L15 15M15 5L5 15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
      </button>
    `;

    document.body.appendChild(reviewPanel);

    document.getElementById('reviewToggleBtn').addEventListener('click', toggleReviewMode);
    document.getElementById('reviewViewCommentsBtn').addEventListener('click', toggleCommentList);
    document.getElementById('reviewExportBtn').addEventListener('click', showExportDialog);
    document.getElementById('reviewCloseBtn').addEventListener('click', hideReviewPanel);

    const dragHandle = reviewPanel.querySelector('.dq-review-panel-drag-handle');
    dragHandle.addEventListener('mousedown', startDrag);
  }

  function updateCommentBadge() {
    const badge = document.getElementById('reviewCommentBadge');
    if (badge) {
      badge.textContent = annotations.length;
      badge.style.display = annotations.length > 0 ? 'flex' : 'none';
    }
  }

  // ==================== 拖动功能 ====================
  function startDrag(e) {
    isDragging = true;
    dragStartX = e.clientX;
    dragStartY = e.clientY;

    const rect = reviewPanel.getBoundingClientRect();
    panelStartX = rect.left;
    panelStartY = rect.top;

    // 移除落地动画类，避免 transform 冲突
    reviewPanel.classList.remove('dq-review-panel-drop');
    // 清除 transform，改用 left/top 定位
    reviewPanel.style.transform = 'none';
    reviewPanel.style.left = panelStartX + 'px';
    reviewPanel.style.top = panelStartY + 'px';
    reviewPanel.style.bottom = 'auto';

    document.addEventListener('mousemove', drag);
    document.addEventListener('mouseup', stopDrag);

    e.preventDefault();
  }

  function drag(e) {
    if (!isDragging) return;

    const deltaX = e.clientX - dragStartX;
    const deltaY = e.clientY - dragStartY;

    const newX = panelStartX + deltaX;
    const newY = panelStartY + deltaY;

    const maxX = window.innerWidth - reviewPanel.offsetWidth;
    const maxY = window.innerHeight - reviewPanel.offsetHeight;

    reviewPanel.style.left = Math.max(0, Math.min(newX, maxX)) + 'px';
    reviewPanel.style.top = Math.max(0, Math.min(newY, maxY)) + 'px';
    reviewPanel.style.right = 'auto';
    reviewPanel.style.bottom = 'auto';
  }

  function stopDrag() {
    isDragging = false;
    document.removeEventListener('mousemove', drag);
    document.removeEventListener('mouseup', stopDrag);
  }

  // ==================== 评审模式切换 ====================
  function toggleReviewMode() {
    if (isReviewMode) {
      exitReviewMode();
    } else {
      enterReviewMode();
    }
  }

  function enterReviewMode() {
    isReviewMode = true;
    document.body.style.cursor = 'crosshair';
    document.addEventListener('click', handleElementClick, true);
    document.addEventListener('mousemove', handleMouseMove, true);

    const btn = document.getElementById('reviewToggleBtn');
    if (btn) {
      btn.textContent = t('endReview');
      btn.classList.remove('dq-review-btn-primary');
      btn.classList.add('dq-review-btn-danger');
    }
  }

  function exitReviewMode() {
    isReviewMode = false;
    document.body.style.cursor = 'default';
    document.removeEventListener('click', handleElementClick, true);
    document.removeEventListener('mousemove', handleMouseMove, true);

    hideHoverOverlay();
    hoveredElement = null;

    if (commentDialog) {
      commentDialog.remove();
      commentDialog = null;
    }

    const btn = document.getElementById('reviewToggleBtn');
    if (btn) {
      btn.textContent = '开始评审';
      btn.classList.remove('dq-review-btn-danger');
      btn.classList.add('dq-review-btn-primary');
    }
  }

  // ==================== 覆盖层管理（架构改进4） ====================
  // 覆盖层在 init 时就创建，生命周期独立于评审模式

  function createHoverOverlay() {
    if (hoverOverlay) return;
    hoverOverlay = document.createElement('div');
    hoverOverlay.style.cssText = `
      position: fixed;
      pointer-events: none;
      z-index: 2147483645;
      border: 2px dashed #93c5fd;
      background: rgba(147, 197, 253, 0.05);
      display: none;
      box-sizing: border-box;
    `;
    document.body.appendChild(hoverOverlay);
  }

  function updateHoverOverlay(element) {
    if (!hoverOverlay || !element) return;
    const rect = element.getBoundingClientRect();
    hoverOverlay.style.display = 'block';
    hoverOverlay.style.top = rect.top + 'px';
    hoverOverlay.style.left = rect.left + 'px';
    hoverOverlay.style.width = rect.width + 'px';
    hoverOverlay.style.height = rect.height + 'px';
  }

  function hideHoverOverlay() {
    if (hoverOverlay) {
      hoverOverlay.style.display = 'none';
    }
  }

  function createSelectOverlay() {
    if (selectOverlay) return;
    selectOverlay = document.createElement('div');
    selectOverlay.style.cssText = `
      position: fixed;
      pointer-events: none;
      z-index: 2147483644;
      border: 3px dashed #fbbf24;
      background: rgba(251, 191, 36, 0.05);
      display: none;
      box-sizing: border-box;
    `;
    document.body.appendChild(selectOverlay);
  }

  function updateSelectOverlay(element) {
    if (!selectOverlay || !element) return;
    const rect = element.getBoundingClientRect();
    selectOverlay.style.display = 'block';
    selectOverlay.style.top = rect.top + 'px';
    selectOverlay.style.left = rect.left + 'px';
    selectOverlay.style.width = rect.width + 'px';
    selectOverlay.style.height = rect.height + 'px';
  }

  function hideSelectOverlay() {
    if (selectOverlay) {
      selectOverlay.style.display = 'none';
    }
    selectedElement = null;
  }

  // ==================== 鼠标事件处理 ====================
  function handleMouseMove(e) {
    if (!isReviewMode) return;

    if (isReviewUIElement(e.target) || e.target === document.body || e.target === document.documentElement) {
      hideHoverOverlay();
      hoveredElement = null;
      document.body.style.cursor = 'default';
      return;
    }

    document.body.style.cursor = 'crosshair';

    if (hoveredElement === e.target) return;

    hoveredElement = e.target;
    updateHoverOverlay(hoveredElement);
  }

  function handleElementClick(e) {
    if (!isReviewMode) return;

    if (isReviewUIElement(e.target)) return;
    if (e.target === document.body || e.target === document.documentElement) return;

    e.stopPropagation();

    hideHoverOverlay();
    hoveredElement = null;

    selectedElement = e.target;
    updateSelectOverlay(selectedElement);

    showCommentDialog(e.target);
  }

  // 判断是否是评审工具自身的 UI 元素
  function isReviewUIElement(target) {
    return target.closest('.dq-review-panel') ||
           target.closest('.dq-review-comment-dialog') ||
           target.closest('.dq-review-marker') ||
           target.closest('.dq-review-comment-list') ||
           target.closest('.dq-review-export-dialog') ||
           target.closest('.dq-review-toast');
  }

  // ==================== 评论对话框 ====================
  function showCommentDialog(element) {
    if (commentDialog) {
      commentDialog.remove();
    }

    commentDialog = document.createElement('div');
    commentDialog.className = 'dq-review-comment-dialog';
    commentDialog.innerHTML = `
      <div class="dq-review-dialog-header">${t('addComment')}</div>
      <div class="dq-review-dialog-body">
        <div class="dq-review-form-group">
          <label>${t('commentContent')}</label>
          <textarea id="reviewCommentContent" class="dq-review-form-control" rows="5" placeholder="${t('commentPlaceholder')}"></textarea>
        </div>
        <div class="dq-review-form-row">
          <div class="dq-review-form-group">
            <label>${t('type')}</label>
            <select id="reviewCommentType" class="dq-review-form-control">
              <option value="${t('typeIssue')}">${t('typeIssue')}</option>
              <option value="${t('typeSuggestion')}">${t('typeSuggestion')}</option>
              <option value="${t('typeDecision')}">${t('typeDecision')}</option>
              <option value="${t('typePending')}">${t('typePending')}</option>
            </select>
          </div>
          <div class="dq-review-form-group">
            <label>${t('priority')}</label>
            <select id="reviewCommentPriority" class="dq-review-form-control">
              <option value="P0">${t('p0')}</option>
              <option value="P1">${t('p1')}</option>
              <option value="P2">${t('p2')}</option>
            </select>
          </div>
        </div>
      </div>
      <div class="dq-review-dialog-footer">
        <button class="dq-review-btn dq-review-btn-secondary" id="reviewCancelBtn">${t('cancel')}</button>
        <button class="dq-review-btn dq-review-btn-primary" id="reviewSaveBtn">${t('save')}</button>
      </div>
    `;

    document.body.appendChild(commentDialog);

    const rect = element.getBoundingClientRect();
    const dialogWidth = 400;
    const dialogHeight = 380;

    let left = rect.right + 10;
    let top = rect.top;

    if (left + dialogWidth > window.innerWidth) {
      left = rect.left - dialogWidth - 10;
    }
    if (left < 0) {
      left = (window.innerWidth - dialogWidth) / 2;
    }
    if (top + dialogHeight > window.innerHeight) {
      top = window.innerHeight - dialogHeight - 20;
    }
    if (top < 0) {
      top = 20;
    }

    commentDialog.style.left = left + 'px';
    commentDialog.style.top = top + 'px';

    document.getElementById('reviewCancelBtn').addEventListener('click', () => {
      commentDialog.remove();
      commentDialog = null;
      hideSelectOverlay();
    });

    document.getElementById('reviewSaveBtn').addEventListener('click', () => {
      saveComment(element);
    });

    document.getElementById('reviewCommentContent').focus();
  }

  // ==================== 保存评论 ====================
  function saveComment(element) {
    const type = document.getElementById('reviewCommentType').value;
    const priority = document.getElementById('reviewCommentPriority').value;
    const content = document.getElementById('reviewCommentContent').value.trim();

    if (!content) {
      alert('请输入评论内容');
      return;
    }

    currentAnnotationId++;
    const annotationId = currentAnnotationId;

    const selector = getElementSelector(element);

    const annotation = {
      id: annotationId,
      type,
      priority,
      content,
      selector,
      timestamp: new Date().toISOString()
    };

    annotations.push(annotation);
    saveAnnotations();

    // 建立运行时映射
    annotationElementMap.set(annotationId, element);

    // 创建角标（不会被销毁，只切换显示）
    createMarker(annotation, element);

    commentDialog.remove();
    commentDialog = null;

    hideSelectOverlay();
    updateCommentBadge();
  }

  // ==================== 角标管理（架构改进1） ====================
  // 角标只创建一次，只切换 display 状态，不销毁

  function createMarker(annotation, element) {
    // 如果已存在，不重复创建
    if (annotationMarkerMap.has(annotation.id)) return;

    const marker = document.createElement('div');
    marker.className = 'dq-review-marker';
    marker.textContent = annotation.id;
    marker.dataset.annotationId = annotation.id;
    marker.dataset.type = annotation.type;

    document.body.appendChild(marker);
    updateMarkerPosition(marker, element);

    // 角标点击：双向联动
    marker.addEventListener('click', (e) => {
      e.stopPropagation();

      // 显示黄色参考框
      selectedElement = element;
      updateSelectOverlay(element);

      // 打开评论列表并高亮对应卡片
      showCommentList();
      highlightCommentCard(annotation.id);
    });

    // 存入映射表
    annotationMarkerMap.set(annotation.id, { marker, element });
  }

  function updateMarkerPosition(marker, element) {
    if (!element || !document.body.contains(element)) {
      marker.style.display = 'none';
      return;
    }

    const rect = element.getBoundingClientRect();

    // 判断元素是否在视口外（被滚动隐藏）
    // 如果元素完全不可见，隐藏角标
    if (rect.bottom < 0 || rect.top > window.innerHeight ||
        rect.right < 0 || rect.left > window.innerWidth) {
      marker.style.display = 'none';
      return;
    }

    marker.style.position = 'fixed';
    marker.style.top = (rect.top - 10) + 'px';
    marker.style.left = (rect.right - 10) + 'px';
    marker.style.display = 'flex';
  }

  // 更新所有可见角标位置
  function updateAllVisibleMarkerPositions() {
    if (!isPanelVisible) return; // 面板隐藏时不需要更新

    annotationMarkerMap.forEach(({ marker, element }, annotationId) => {
      // 如果运行时引用丢失（页面刷新后），尝试重新查找
      if (!element || !document.body.contains(element)) {
        const annotation = annotations.find(a => a.id === annotationId);
        if (annotation) {
          const found = findElementSafe(annotation.selector);
          if (found) {
            annotationMarkerMap.set(annotationId, { marker, element: found });
            annotationElementMap.set(annotationId, found);
            element = found;
          }
        }
      }
      updateMarkerPosition(marker, element);
    });
  }

  // 重建角标并显示（面板打开时调用）
  function rebuildAndShowMarkers() {
    annotations.forEach(annotation => {
      if (annotationMarkerMap.has(annotation.id)) {
        // 角标已存在，显示并更新位置
        const { marker, element } = annotationMarkerMap.get(annotation.id);
        // 检查元素是否还在 DOM 中
        if (element && document.body.contains(element)) {
          updateMarkerPosition(marker, element);
        } else {
          // 运行时引用丢失，尝试通过 selector 找回
          const found = findElementSafe(annotation.selector);
          if (found) {
            annotationMarkerMap.set(annotation.id, { marker, element: found });
            annotationElementMap.set(annotation.id, found);
            updateMarkerPosition(marker, found);
          } else {
            marker.style.display = 'none';
          }
        }
      } else {
        // 角标不存在（首次加载或页面刷新后），创建
        const element = findElementSafe(annotation.selector);
        if (element) {
          annotationElementMap.set(annotation.id, element);
          createMarker(annotation, element);
        }
      }
    });
  }

  // 隐藏所有角标（面板关闭时调用，不销毁）
  function hideAllMarkers() {
    annotationMarkerMap.forEach(({ marker }) => {
      marker.style.display = 'none';
    });
  }

  // ==================== 增强的元素选择器（架构改进2） ====================

  function getElementSelector(element) {
    // 优先用 ID（最稳定）
    if (element.id) {
      return '#' + cssEscape(element.id);
    }

    const path = [];
    let current = element;

    while (current && current.nodeType === Node.ELEMENT_NODE) {
      let selector = current.nodeName.toLowerCase();

      // 用 CSS.escape 安全转义 class 名
      if (current.className && typeof current.className === 'string') {
        const classes = current.className.split(' ')
          .filter(c => c.trim() && !c.startsWith('dq-review-'))
          .map(c => cssEscape(c.trim()));
        if (classes.length > 0) {
          selector += '.' + classes.join('.');
        }
      }

      // nth-child 保证唯一性
      if (current.parentNode) {
        const siblings = Array.from(current.parentNode.children);
        const index = siblings.indexOf(current) + 1;
        selector += `:nth-child(${index})`;
      }

      path.unshift(selector);
      current = current.parentNode;

      if (current && (current.nodeName === 'BODY' || current.nodeName === 'HTML')) {
        break;
      }

      if (path.length > 8) break;
    }

    return path.join(' > ');
  }

  // CSS.escape polyfill（兼容不支持的环境）
  function cssEscape(value) {
    if (typeof CSS !== 'undefined' && CSS.escape) {
      return CSS.escape(value);
    }
    // 手动转义特殊字符
    return value.replace(/([^\w-])/g, '\\$1');
  }

  // 安全查找元素（容错）
  function findElementSafe(selector) {
    if (!selector) return null;
    try {
      return document.querySelector(selector);
    } catch (e) {
      console.warn('[Review Extension V2] selector 查找失败，尝试备用方案:', selector, e.message);
      // 备用：去掉类名部分，只用标签 + nth-child
      try {
        const simplified = selector.replace(/\.[^:>\s]+/g, '');
        if (simplified !== selector) {
          return document.querySelector(simplified);
        }
      } catch (e2) {
        console.warn('[Review Extension V2] 备用 selector 也失败:', e2.message);
      }
      return null;
    }
  }

