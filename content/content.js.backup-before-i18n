    // 卡片点击：双向联动
    listBody.querySelectorAll('.dq-review-comment-item').forEach(itemEl => {
      const annotationId = parseInt(itemEl.dataset.annotationId);

      itemEl.addEventListener('click', function(e) {
        if (e.target.closest('.dq-review-delete-btn') || e.target.closest('.dq-review-edit-btn')) return;

        // 选中卡片
        document.querySelectorAll('.dq-review-comment-item').forEach(el => el.classList.remove('selected'));
